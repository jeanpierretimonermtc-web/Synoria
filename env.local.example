# ==============================================================================
# env.local.example — Template pour créer .env.local
#
# Copier ce fichier en .env.local à la racine et remplir les valeurs.
# .env.local est git-ignoré — ce fichier exemple peut être commité.
#
# Usage : injecté dans le bundle Electron par vite.config.ts au build.
# ==============================================================================

# Clé publique Ed25519 (PEM) — valide les jetons offline.
# Générer une nouvelle paire :
#   node -e "
#     const {generateKeyPairSync}=require('node:crypto');
#     const {publicKey,privateKey}=generateKeyPairSync('ed25519',{
#       publicKeyEncoding:{type:'spki',format:'pem'},
#       privateKeyEncoding:{type:'pkcs8',format:'pem'}
#     });
#     console.log('PUBLIC:\n'+publicKey);
#     console.log('PRIVATE (→ supabase/.env):\n'+privateKey);
#   "
LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<coller la clé publique ici>
-----END PUBLIC KEY-----"

# Supabase — Project Settings → API → Project URL & anon key
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Google Calendar OAuth (console.cloud.google.com → APIs & Services → Identifiants)
GCAL_CLIENT_ID=<client_id>.apps.googleusercontent.com
GCAL_CLIENT_SECRET=GOCSPX-...

# Comptes propriétaire — accès admin illimité à vie (séparés par virgule)
OWNER_EMAILS=email1@domaine.com,email2@domaine.com
