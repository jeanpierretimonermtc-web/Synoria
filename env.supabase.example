# ==============================================================================
# env.supabase.example — Template pour créer supabase/.env
#
# Copier ce fichier en supabase/.env et remplir les valeurs.
# supabase/.env est git-ignoré — ce fichier exemple peut être commité.
#
# Pousser les secrets vers Supabase :
#   supabase secrets set --env-file supabase/.env
#
# Les SUPABASE_* sont ignorés par la commande (auto-injectés par Supabase).
# ==============================================================================

# Supabase — pour référence uniquement (ignorés par secrets set)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Clé privée Ed25519 — signe les jetons offline dans license-check.
# Clé publique correspondante : .env.local → LICENSE_PUBLIC_KEY
# Format : une seule ligne avec \n littéraux
LICENSE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<base64>\n-----END PRIVATE KEY-----"

# Stripe — dashboard.stripe.com → Developers → API keys
# Utiliser sk_live_ en production, sk_test_ pour les tests
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — Stripe Dashboard → Products → copier les IDs price_1...
STRIPE_PRICE_SYNORIA_ANNUAL=price_1...
STRIPE_PRICE_SYNORIA_6_MONTHS=price_1...
