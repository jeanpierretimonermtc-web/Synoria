          "hint": "Sélectionner les principes dominants du tableau clinique"
        },
        {
          "id": "causesMaladie",
          "type": "checkboxgroup",
          "label": "Causes et facteurs pathogènes",
          "options": ["Vent (Feng)", "Froid (Han)", "Chaleur (Re)", "Humidité (Shi)", "Sécheresse (Zao)", "Feu (Huo)", "Chaleur-Été (Shu)", "Colère / Foie", "Joie excessive / Cœur", "Tristesse / Poumon", "Inquiétude / Rate-Poumon", "Peur / Rein", "Choc / Cœur-Rein", "Surmenage", "Alimentation déséquilibrée", "Traumatisme", "Stase de sang (Yu Xue)", "Mucosités (Tan)"],
          "width": "full"
        },
        {
          "id": "sep1", "type": "separator", "label": ""
