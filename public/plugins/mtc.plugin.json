          "label": "État général du patient aujourd'hui",
          "min": 1,
          "max": 10,
          "width": "third",
          "hint": "1 = très mauvais · 10 = excellent"
        },
        {
          "id": "conseilsHygieneDietetique",
          "type": "richtext",
          "label": "Conseils hygiéno-diététiques",
          "placeholder": "Alimentation adaptée au diagnostic (aliments réchauffants/rafraîchissants/neutres), hydratation, activité physique, repos, gestion des émotions…",
          "width": "full",
          "minHeight": 90
        },
        {
          "id": "exercices",
