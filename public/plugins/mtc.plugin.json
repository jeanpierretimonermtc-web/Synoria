          "minHeight": 90
        },
        {
          "id": "cinqElements",
          "type": "radio",
          "label": "Élément dominant (5 Éléments / Wu Xing)",
          "options": ["Bois (Foie / VB)", "Feu (Cœur / IG)", "Terre (Rate / Estomac)", "Métal (Poumon / GI)", "Eau (Rein / Vessie)"],
          "width": "half"
        },
        {
          "id": "meridiensPrincipaux",
          "type": "richtext",
          "label": "Méridiens principaux impliqués",
          "placeholder": "Méridiens sur lesquels portera le traitement, avec justification énergétique…",
          "width": "half",
          "minHeight": 75
        },
        {
          "id": "principeTraitement",
          "type": "richtext",
          "label": "Principe de traitement",
          "placeholder": "Ex : Tonifier le Yin du Rein, disperser la stagnation du Foie, réguler le Qi et le Xue, réchauffer et tonifier le Yang…",
          "width": "full",
          "minHeight": 85
        }
      ]
    },

    {
      "id": "traitement",
      "title": "Traitement",
      "icon": "🌿",
      "accentColor": "#2B8058",
      "fields": [
        {
          "id": "pointsPrincipaux",
