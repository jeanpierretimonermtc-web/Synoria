{
  "id": "mtc",
  "name": "MTC — Médecine Traditionnelle Chinoise",
  "specialty": "Médecine Traditionnelle Chinoise",
  "version": "1.0.0",
  "description": "Fiche d'anamnèse MTC complète : interrogatoire, inspection, pouls, diagnostic énergétique et traitement. Pour praticiens d'acupuncture et de MTC.",
  "icon": "☯",
  "accentColor": "#B04040",

  "sections": [

    {
      "id": "interrogatoire",
      "title": "Interrogatoire et anamnèse",
      "icon": "📋",
      "accentColor": "#B04040",
      "fields": [
        {
          "id": "plainte",
          "type": "richtext",
          "label": "Plainte principale",
          "placeholder": "Motif de consultation détaillé, symptômes principaux, localisation, intensité, facteurs aggravants et améliorants…",
          "width": "full",
          "minHeight": 100
        },
        {
          "id": "dureeSymptomes",
          "type": "radio",
          "label": "Ancienneté des symptômes",
          "options": ["Aigu (< 1 semaine)", "Récent (< 1 mois)", "Sub-aigu (1–3 mois)", "Chronique (3–6 mois)", "Chronique ancien (> 6 mois)"],
          "width": "half"
        },
        {
          "id": "debutCirconstances",
          "type": "richtext",
          "label": "Circonstances d'apparition",
          "placeholder": "Contexte de survenue : effort, stress, exposition au froid/chaud, choc émotionnel, changement alimentaire…",
          "width": "half",
          "minHeight": 75
        },
        {
          "id": "antecedents",
          "type": "richtext",
          "label": "Antécédents médicaux et chirurgicaux",
          "placeholder": "Pathologies chroniques, opérations, hospitalisations, traumatismes importants…",
          "width": "half",
          "minHeight": 80
        },
        {
          "id": "antecedentsFamiliaux",
          "type": "richtext",
          "label": "Antécédents familiaux",
          "placeholder": "Maladies héréditaires ou à tendance familiale…",
          "width": "half",
          "minHeight": 80
        },
        {
          "id": "traitements",
          "type": "richtext",
          "label": "Traitements en cours",
          "placeholder": "Médicaments, compléments alimentaires, autres thérapies…",
          "width": "full",
          "minHeight": 70
        }
      ]
    },

    {
      "id": "dix_questions",
      "title": "Les dix questions (Shi Wen)",
      "icon": "🌡",
      "accentColor": "#B05030",
      "fields": [
        {
          "id": "sensationThermique",
          "type": "checkboxgroup",
          "label": "1. Sensations thermiques",
          "options": ["Frissons", "Aversion au froid", "Aversion à la chaleur", "Fièvre", "Sensation de froid interne", "Chaleur des paumes / plantes / thorax", "Bouffées de chaleur", "Mains et pieds froids"],
          "width": "full"
        },
        {
          "id": "transpiration",
          "type": "checkboxgroup",
          "label": "2. Transpiration",
          "options": ["Transpiration spontanée (diurne)", "Sueurs nocturnes", "Absence de transpiration", "Transpiration abondante", "Transpiration lors des repas", "Transpiration des paumes"],
          "width": "full"
        },
        {
          "id": "douleurs",
          "type": "richtext",
          "label": "3. Douleurs",
          "placeholder": "Localisation, type (oppression, piqûre, brûlure, crampe, lourdeur…), facteurs améliorants (chaleur, froid, pression, mouvement)…",
          "width": "full",
          "minHeight": 80
        },
        {
          "id": "sep1", "type": "separator", "label": ""
        },
        {
          "id": "urinaires",
          "type": "checkboxgroup",
          "label": "4. Urines",
          "options": ["Normales", "Abondantes / pâles", "Peu abondantes / foncées", "Fréquentes", "Nycturie", "Difficultés à uriner", "Brûlures à la miction"],
          "width": "half"
        },
        {
          "id": "selles",
          "type": "checkboxgroup",
          "label": "4. Selles",
          "options": ["Normales", "Constipation", "Diarrhée", "Selles molles", "Selles alternées", "Urgences à la défécation", "Douleurs à la défécation", "Présence de mucus"],
          "width": "half"
        },
        {
          "id": "sep2", "type": "separator", "label": ""
        },
        {
          "id": "appetit",
          "type": "checkboxgroup",
          "label": "5. Appétit et alimentation",
          "options": ["Appétit normal", "Manque d'appétit", "Appétit excessif", "Faim sans envie de manger", "Goût acide en bouche", "Goût amer en bouche", "Goût sucré en bouche", "Bouche sèche", "Nausées", "Vomissements", "Reflux / renvois"],
          "width": "full"
        },
        {
          "id": "soif",
          "type": "radio",
          "label": "5. Soif",
          "options": ["Normale", "Absence de soif", "Soif intense — préférence froide", "Soif modérée — préférence chaude", "Soif sans désir de boire"],
          "width": "half"
        },
        {
          "id": "sep3", "type": "separator", "label": ""
        },
        {
          "id": "sommeil",
          "type": "checkboxgroup",
          "label": "6. Sommeil",
          "options": ["Normal", "Insomnie d'endormissement", "Réveils nocturnes", "Réveil matinal précoce", "Sommeil agité", "Rêves abondants / agités", "Cauchemars", "Somnolence diurne", "Hypersomnie"],
          "width": "full"
        },
        {
          "id": "sep4", "type": "separator", "label": ""
        },
        {
          "id": "teteCou",
          "type": "checkboxgroup",
          "label": "7. Tête, cou et sens",
          "options": ["Céphalées", "Vertiges", "Acouphènes", "Hypoacousie", "Troubles visuels", "Yeux secs / rouges", "Nez bouché", "Epistaxis", "Gorge sèche / irritée", "Sécheresse buccale"],
          "width": "full"
        },
        {
          "id": "sep5", "type": "separator", "label": ""
        },
        {
          "id": "energy",
          "type": "checkboxgroup",
          "label": "8. Énergie et vitalité",
          "options": ["Fatigue générale", "Fatigue matinale", "Fatigue après les repas", "Fatigue en fin de journée", "Lassitude des membres", "Sensation de lourdeur", "Essoufflement à l'effort", "Palpitations"],
          "width": "full"
        },
        {
          "id": "sep6", "type": "separator", "label": ""
        },
        {
          "id": "sphèreGyneco",
          "type": "richtext",
          "label": "9. Sphère gynécologique / reproductive (si applicable)",
          "placeholder": "Cycles : régularité, durée, abondance, couleur, douleurs (SPM, dysménorrhée). Ménopause, contraception. Grossesses éventuelles…",
          "width": "full",
          "minHeight": 80
        },
        {
          "id": "sep7", "type": "separator", "label": ""
        },
        {
          "id": "emotions",
          "type": "checkboxgroup",
          "label": "10. État émotionnel et mental",
          "options": ["Anxiété / inquiétude excessive", "Tristesse / mélancolie", "Colère / irritabilité", "Peur / frayeur", "Choc émotionnel récent", "Ruminations / obsessions", "Joie excessive / agitation", "Dépression / manque de motivation"],
          "width": "full"
        },
        {
          "id": "contextePsycho",
          "type": "richtext",
          "label": "Contexte psychosocial",
          "placeholder": "Stress professionnel ou personnel, deuil, séparation, surmenage, événements de vie récents…",
          "width": "full",
          "minHeight": 75
        }
      ]
    },

    {
      "id": "observation",
      "title": "Observation et inspection",
      "icon": "👁",
      "accentColor": "#8B6038",
      "fields": [
        {
          "id": "constitutionType",
          "type": "radio",
          "label": "Constitution (morphologie dominante)",
          "options": ["Mince / longiligne", "Normal / harmonieux", "Trapu / musclé", "Enrobé / adipeux", "Fragile / délicat"],
          "width": "half"
        },
        {
          "id": "teint",
          "type": "checkboxgroup",
          "label": "Teint et coloris du visage",
          "options": ["Normal", "Pâle", "Blanc / terne", "Rouge / vermeil", "Jaune / terreux", "Verdâtre", "Grisâtre / sombre", "Brillant / huileux", "Mat / sans éclat"],
          "width": "half"
        },
        {
          "id": "sep1", "type": "separator", "label": ""
        },
        {
          "id": "langueCouleur",
          "type": "radio",
          "label": "Langue — Couleur du corps",
          "options": ["Rose normal", "Pâle", "Rouge clair", "Rouge vif", "Écarlate", "Violet / bleuâtre", "Violet pâle"],
          "width": "third"
        },
        {
          "id": "langueEnduit",
          "type": "radio",
          "label": "Langue — Enduit",
          "options": ["Mince blanc (normal)", "Blanc épais", "Jaune mince", "Jaune épais", "Grisâtre", "Noirâtre", "Sans enduit (miroir)", "Enduit pelant"],
          "width": "third"
        },
        {
          "id": "langueHumidite",
          "type": "radio",
          "label": "Langue — Humidité",
          "options": ["Humide (normal)", "Sèche", "Collante / grasse", "Très humide / glissante"],
          "width": "third"
        },
        {
          "id": "langueCorps",
          "type": "checkboxgroup",
          "label": "Langue — Forme et signes particuliers",
          "options": ["Normale", "Gonflée / boursouflée", "Fine / maigre", "Rigide / raide", "Tremblements", "Fissures longitudinales", "Fissures multiples", "Pointe rouge", "Indentations dentaires (bords)", "Déviation"],
          "width": "full"
        },
        {
          "id": "langueNotes",
          "type": "richtext",
          "label": "Notes complémentaires (langue)",
          "placeholder": "Topographie (zones), couleur des bords, sous-face linguale (veines sublinguales)…",
          "width": "full",
          "minHeight": 65
        },
        {
          "id": "sep2", "type": "separator", "label": ""
        },
        {
          "id": "voix",
          "type": "radio",
          "label": "Voix et respiration",
          "options": ["Voix forte et claire", "Voix faible / essoufflée", "Voix rauque / enrouée", "Voix plaintive", "Soupirs fréquents", "Toux sèche", "Toux grasse"],
          "width": "half"
        },
        {
          "id": "observationGenerale",
          "type": "richtext",
          "label": "Observations générales",
          "placeholder": "Posture, démarche, vitalité du regard, comportement, morphologie particulière, traits du visage…",
          "width": "half",
          "minHeight": 80
        }
      ]
    },

    {
      "id": "pouls",
      "title": "Prise des pouls",
      "icon": "🫀",
      "accentColor": "#3B6898",
      "fields": [
        {
          "id": "poulsRythme",
          "type": "radio",
          "label": "Rythme global",
          "options": ["Normal (60–90 bpm)", "Lent (< 60 bpm)", "Rapide (> 90 bpm)", "Irrégulier", "Intermittent"],
          "width": "third"
        },
        {
          "id": "poulsForce",
          "type": "radio",
          "label": "Force globale",
          "options": ["Vide / faible (Xu)", "Normal", "Plein / fort (Shi)"],
          "width": "third"
        },
        {
          "id": "poulsProfondeur",
          "type": "radio",
          "label": "Profondeur globale",
          "options": ["Superficiel (Fu)", "Moyen", "Profond (Chen)"],
          "width": "third"
        },
        {
          "id": "poulsCaracteristiques",
          "type": "checkboxgroup",
          "label": "Qualités des pouls",
          "options": ["Glissant (Hua)", "Rugueux (Se)", "En corde (Xian)", "En fil (Xi / Ru)", "En hamac (Hong)", "Bondissant (Dong)", "Serré (Jin)", "Ample (Da)", "Mou (Ruan)", "Faible (Ruo)", "Lent (Chi)", "Rapide (Shu)", "Flottant (Fu)", "Profond (Chen)", "Vide (Xu)", "Plein (Shi)"],
          "width": "full"
        },
        {
          "id": "sep1", "type": "separator", "label": ""
        },
        {
          "id": "poulsDroit",
          "type": "richtext",
          "label": "Pouls droit — Cun / Guan / Chi",
          "placeholder": "Ex : Cun : flottant-vide / Guan : en corde / Chi : profond-lent…",
          "width": "half",
          "minHeight": 70
        },
        {
          "id": "poulsGauche",
          "type": "richtext",
          "label": "Pouls gauche — Cun / Guan / Chi",
          "placeholder": "Ex : Cun : flottant-plein / Guan : en fil / Chi : profond-vide…",
          "width": "half",
          "minHeight": 70
        },
        {
          "id": "poulsNotes",
          "type": "richtext",
          "label": "Notes et interprétation des pouls",
          "placeholder": "Corrélations avec les organes, évolution par rapport aux séances précédentes, particularités…",
          "width": "full",
          "minHeight": 75
        }
      ]
    },

    {
      "id": "diagnostic",
      "title": "Diagnostic énergétique",
      "icon": "🔵",
      "accentColor": "#6B3A8A",
      "fields": [
        {
          "id": "huitPrincipes",
          "type": "checkboxgroup",
          "label": "Huit Principes (Ba Gang)",
          "options": ["Yin", "Yang", "Biao — Extérieur", "Li — Intérieur", "Han — Froid", "Re — Chaud", "Xu — Vide", "Shi — Plénitude"],
